    {
      "name": "Travel",
      "description": "Bookings, itineraries, transport.",
      "clean_action": "none",
      "clean_older_than_days": 0,
      "rules": [
        { "weight": 4, "subject_keywords": ["itinerary", "booking", "reservation", "boarding pass", "flight", "check-in", "hotel confirmation", "e-ticket"] },
        { "weight": 3, "from_contains": ["booking.com", "airbnb", "expedia", "agoda", "airlines", "trip.com", "getgo", "grab"] }
