    {
      "name": "Promotions",
      "description": "Marketing, sales, discounts, offers.",
      "clean_action": "none",
      "clean_older_than_days": 0,
      "rules": [
        { "weight": 4, "subject_keywords": ["sale", "% off", "discount", "deal", "offer", "coupon", "promo", "save ", "save more", "limited time", "black friday", "cyber monday", "last chance", "new arrivals", "flexiloan", "shop "] },
        { "weight": 3, "from_contains": ["marketing@", "deals@", "offers@", "hello@beauty", "myfave", "info.foodpanda", "mktg.", "braunbuffel", "info.emeritus"] },
        { "weight": 1, "has_list_unsubscribe": true }
