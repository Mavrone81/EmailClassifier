{
  "categories": [
    {
      "name": "Spam-suspect",
      "description": "Likely junk / phishing — moved to Gmail's Spam (Junk) folder.",
      "clean_action": "spam",
      "clean_older_than_days": 0,
      "rules": [
        { "weight": 6, "gmail_labels": ["SPAM"] },
        { "weight": 6, "subject_keywords": ["you won", "you have won", "winner", "congratulations you", "claim your prize", "claim your reward", "you have been selected", "free gift card", "viagra", "cialis", "crypto giveaway", "double your bitcoin", "wire transfer", "unclaimed funds", "nigerian prince", "verify your account immediately", "tax refund pending", "you are a lucky"] },
        { "weight": 4, "from_contains": ["lucky-draw", "prize-", "winner@", "rewards-", "giveaway", ".top", ".xyz"] }
      ]
    },
    {
      "name": "Security",
      "description": "Sign-in alerts, OTP, password resets, 2FA, account verification.",
      "clean_action": "none",
      "rules": [
        { "weight": 6, "subject_keywords": ["security alert", "new sign-in", "new login", "sign-in attempt", "login attempt", "unusual activity", "suspicious", "verify your", "verification code", "one-time password", "one time password", "otp", "2fa", "two-factor", "reset your password", "password was", "password changed", "confirm your email", "was this you"] },
        { "weight": 3, "body_keywords": ["verification code", "one-time", "we noticed a new sign-in", "verify it was you"] }
      ]
    },
    {
      "name": "Government",
      "description": "Singapore government & statutory bodies.",
      "clean_action": "none",
      "rules": [
        { "weight": 6, "from_domains": ["hdb.gov.sg", "singpass.gov.sg", "iras.gov.sg", "cpf.gov.sg", "mom.gov.sg", "ica.gov.sg", "lta.gov.sg", "mindef.gov.sg", "moh.gov.sg", "onepass.gov.sg"] },
        { "weight": 5, "from_contains": [".gov.sg", "singpass", "@mindef", "@ns.sg", "nsportal"] },
        { "weight": 3, "subject_keywords": ["hdb", "singpass", "cpf", "iras", "mindef", "ns ", "reservist", "ippt", "statutory"] }
      ]
    },
    {
      "name": "DNS",
