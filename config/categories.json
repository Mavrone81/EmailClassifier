{
  "categories": [
    {
      "name": "Spam-suspect",
      "description": "Likely junk / phishing — moved to Gmail's Spam (Junk) folder.",
      "clean_action": "spam",
      "clean_older_than_days": 0,
      "rules": [
        { "weight": 6, "gmail_labels": ["SPAM"] },
        { "weight": 6, "subject_keywords": ["you won", "you have won", "winner", "congratulations you", "claim your prize", "claim your reward", "you have been selected", "free gift card", "viagra", "cialis", "crypto giveaway", "double your bitcoin", "urgent action required", "wire transfer", "unclaimed funds", "nigerian prince", "verify your account immediately", "account suspended", "confirm your password", "tax refund pending", "you are a lucky"] },
        { "weight": 4, "body_keywords": ["send your bank details", "wire the amount", "western union", "beneficiary", "this is not a scam", "100% free", "risk-free investment"] },
        { "weight": 4, "from_contains": ["lucky-draw", "prize-", "winner@", "rewards-", "giveaway", ".top", ".xyz"] }
      ]
    },
    {
      "name": "Finance",
      "description": "Banking, payments, transactions, statements.",
      "clean_action": "none",
      "clean_older_than_days": 0,
      "rules": [
        { "weight": 5, "from_contains": ["ibanking.alert", "digibank", "@dbs.com", "paypal", "stripe", "@ocbc", "@posb", "billing@", "@uob"] },
        { "weight": 4, "subject_keywords": ["invoice", "receipt", "payment", "statement", "transaction", "balance", "refund", "paynow", "nets", "digibank", "payment failed", "your bill"] },
        { "weight": 3, "body_keywords": ["paynow", "nets scan", "transaction was completed", "transaction ref", "we refer to your", "you've received a transfer", "payment for subscription", "we weren't able to charge"] }
      ]
    },
    {
      "name": "Jobs",
      "description": "Job alerts, recruiter messages, hiring & career listings.",
      "clean_action": "none",
      "clean_older_than_days": 0,
      "rules": [
        { "weight": 6, "from_contains": ["jobalerts", "jobs-noreply", "jobs-listings", "@e.jobstreet.com", "jobpostings"] },
        { "weight": 6, "from_domains": ["jobstreet.com", "indeed.com", "mycareersfuture.gov.sg", "glints.com", "efinancialcareers.com"] },
        { "weight": 4, "subject_keywords": ["job alert", "view jobs", "job recommendations", "jobs for you", "we're hiring", "is hiring", "is also hiring", "new role", "see your opportunities", "head of", "engineer:", "manager:", "salary"] },
        { "weight": 3, "body_keywords": ["job recommendations", "view jobs", "roles could be a match", "we're hiring", "is hiring", "apply now", "view job", "matched your search profile", "see your opportunities"] }
      ]
    },
    {
      "name": "Shopping",
      "description": "Order confirmations, shipping & delivery updates.",
      "clean_action": "none",
      "clean_older_than_days": 0,
      "rules": [
        { "weight": 5, "from_contains": ["shop.tiktok", "shopee", "lazada", "amazon", "@order", "orders@"] },
        { "weight": 4, "subject_keywords": ["your order", "order confirmed", "order is confirmed", "order delivered", "order shipped", "tracking", "out for delivery", "shipment", "purchase"] },
        { "weight": 3, "body_keywords": ["your order is confirmed", "order delivered", "tracking info", "is being prepared for shipment", "shopping basket"] }
      ]
    },
    {
      "name": "Social",
      "description": "Social network and messaging notifications.",
      "clean_action": "none",
      "clean_older_than_days": 0,
      "rules": [
        { "weight": 4, "from_contains": ["messages-noreply@linkedin", "notification@service.tiktok", "facebookmail", "@instagram", "@x.com", "@twitter"] },
        { "weight": 3, "from_domains": ["facebookmail.com", "instagram.com", "pinterest.com", "reddit.com"] },
        { "weight": 3, "subject_keywords": ["sent you a message", "new follower", "tagged you", "wants to connect", "liked your", "commented on", "mentioned you", "reply on", "see your opportunities", "getting noticed"] }
      ]
    },
    {
      "name": "Newsletters",
      "description": "Subscriptions, digests, articles you opted into.",
      "clean_action": "none",
      "clean_older_than_days": 0,
      "rules": [
        { "weight": 4, "from_contains": ["seekingalpha", "substack.com", "medium.com", "newsletters-noreply", "@mail.galaxy.ai", "pysource", "notifications@acquire.com", "digest@"] },
        { "weight": 3, "subject_keywords": ["newsletter", "digest", "weekly", "this week", "roundup", "edition", "bulletin", "must reads", "latest article", "news quiz", "daily listing"] }
      ]
