    },
    {
      "name": "Work",
      "description": "Dev tooling, documents, calendar, team.",
      "clean_action": "none",
      "clean_older_than_days": 0,
      "rules": [
        { "weight": 5, "from_domains": ["github.com", "gitlab.com", "atlassian.net", "slack.com", "notion.so", "asana.com"] },
        { "weight": 3, "subject_keywords": ["pull request", "merge request", "pipeline", "deploy", "ticket", "meeting", "agenda"] }
