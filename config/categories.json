    },
    {
      "name": "Updates",
      "description": "Account, service, system & government notifications.",
      "clean_action": "none",
      "clean_older_than_days": 0,
      "rules": [
        { "weight": 3, "subject_keywords": ["notification", "alert", "verify", "confirm your", "security", "sign-in", "otp", "maintenance", "new listing", "invited you", "upcoming event", "domain name"] },
        { "weight": 3, "from_contains": ["donotreply@sgnic", "notification@hdb", "calendar-notification@google", "@exabytes", "no-reply-", "@mail.anthropic.com"] },
        { "weight": 1, "from_contains": ["notifications@", "alerts@", "updates@"] }
